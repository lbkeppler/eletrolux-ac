  "components": {
    "schemas": {
      "Appliance": {
        "type": "object",
        "properties": {
          "applianceId": {
            "type": "string",
            "description": "Appliance ID",
            "example": "999011524_00:94700001-443E070ABC12"
          },
          "applianceName": {
            "type": "string",
            "description": "Appliance name",
            "example": "My Air Conditioner"
          },
          "applianceType": {
            "type": "string",
            "description": "Appliance type",
            "example": "AC"
          },
          "created": {
            "type": "string",
            "description": "Timestamp indicating the creation time of this appliance",
            "format": "date-time",
            "example": "2022-07-20T08:19:06.521Z"
          }
        }
      },
      "ApplianceState": {
        "type": "object",
        "properties": {
          "applianceId": {
            "type": "string",
            "description": "Appliance ID",
            "example": "999011524_00:94700001-443E070ABC12"
          },
          "connectionState": {
            "type": "string",
            "description": "Connection state",
            "example": "connected"
          },
          "status": {
            "type": "string",
            "description": "Status",
            "example": "enabled"
          },
          "properties": {
            "$ref": "#/components/schemas/ApplianceStateProperties"
          }
        }
      },
      "ApplianceStateProperties": {
        "type": "object",
        "properties": {
          "reported": {
            "type": "object"
          }
        },
        "description": "Properties",
        "example": {
          "reported": {
            "sleepMode": "OFF",
            "cleanAirMode": "OFF",
            "applianceInfo": {
              "applianceType": "AC"
            },
            "temperatureRepresentation": "CELSIUS",
            "displayLight": "DISPLAY_LIGHT_1",
            "uiLockMode": false,
            "schedulerMode": "OFF",
            "targetTemperatureF": 64.4,
            "targetTemperatureC": 18,
            "applianceState": "OFF",
            "FilterState": "GOOD",
            "mode": "OFF",
            "alerts": [],
            "ambientTemperatureF": 71.6,
            "filterState": "GOOD",
            "fanSpeedSetting": "AUTO",
            "networkInterface": {
              "linkQualityIndicator": "VERY_GOOD",
              "otaState": "IDLE",
              "swVersion": "v1.9.1_srac",
              "swAncAndRevision": "S00006778A",
              "niuSwUpdateCurrentDescription": "A16323311A-S00006778A"
            },
            "verticalSwing": "OFF",
            "startTime": 54000,
            "stopTime": -1,
            "ambientTemperatureC": 22,
            "connectivityState": "connected"
          }
        }
      },
      "ApplianceInfo": {
        "type": "object",
        "properties": {
          "applianceInfo": {
            "$ref": "#/components/schemas/ApplianceInfoDTO"
          },
          "capabilities": {
            "type": "object"
          }
        },
        "example": {
          "applianceInfo": {
            "serialNumber": "94700001",
            "pnc": "999011524",
            "brand": "FRIGIDAIRE",
            "deviceType": "PORTABLE_AIR_CONDITIONER",
            "model": "GHPC132AB1",
            "variant": "13KBTU",
            "colour": "WHITE"
          },
          "capabilities": {
            "alerts": {
              "access": "read",
              "type": "alert",
              "values": {
                "BUS_HIGH_VOLTAGE": {},
                "COMMUNICATION_FAULT": {},
                "DRAIN_PAN_FULL": {},
                "INDOOR_DEFROST_THERMISTOR_FAULT": {}
              }
            },
            "ambientTemperatureC": {
              "access": "read",
              "type": "temperature"
            },
            "ambientTemperatureF": {
              "access": "read",
              "type": "temperature"
            },
            "applianceState": {
              "access": "read",
              "type": "string",
              "values": {
                "OFF": {},
                "RUNNING": {}
              }
            },
            "cleanAirMode": {
              "access": "readwrite",
              "type": "string",
              "values": {
                "OFF": {},
                "ON": {}
              }
            },
            "displayLight": {
              "access": "readwrite",
              "type": "string",
              "values": {
                "DISPLAY_LIGHT_0": {},
                "DISPLAY_LIGHT_1": {}
              }
            },
            "executeCommand": {
              "access": "write",
              "schedulable": true,
              "type": "string",
              "values": {
                "OFF": {},
                "ON": {}
              }
            },
            "fanSpeedSetting": {
              "access": "readwrite",
              "schedulable": true,
              "type": "string",
              "values": {
                "AUTO": {},
                "HIGH": {},
                "LOW": {},
                "MIDDLE": {}
              }
            },
            "fanSpeedState": {
              "access": "read",
              "type": "string",
              "values": {
                "HIGH": {},
                "LOW": {},
                "MIDDLE": {}
              }
            },
            "filterState": {
              "access": "read",
              "type": "string",
              "values": {
                "BUY": {},
                "CHANGE": {},
                "CLEAN": {},
                "GOOD": {}
              }
            },
            "mode": {
              "access": "readwrite",
              "schedulable": true,
              "triggers": [
                {
                  "action": {
                    "fanSpeedSetting": {
                      "access": "readwrite",
                      "values": {
                        "HIGH": {},
                        "LOW": {},
                        "MIDDLE": {}
                      }
                    }
                  },
                  "condition": {
                    "operand_1": "value",
                    "operand_2": "FANONLY",
                    "operator": "eq"
                  }
                },
                {
                  "action": {
                    "fanSpeedSetting": {
                      "access": "readwrite",
                      "values": {
                        "AUTO": {},
                        "HIGH": {},
                        "LOW": {},
                        "MIDDLE": {}
                      }
                    }
                  },
                  "condition": {
                    "operand_1": "value",
                    "operand_2": "FANONLY",
                    "operator": "ne"
                  }
                },
                {
                  "action": {
                    "fanSpeedSetting": {
                      "access": "read"
                    }
                  },
                  "condition": {
                    "operand_1": "value",
                    "operand_2": "DRY",
                    "operator": "eq"
                  }
                },
                {
                  "action": {
                    "fanSpeedSetting": {
                      "access": "readwrite"
                    }
                  },
                  "condition": {
                    "operand_1": "value",
                    "operand_2": "DRY",
                    "operator": "ne"
                  }
                },
                {
                  "action": {
                    "targetTemperatureC": {
                      "disabled": true,
                      "type": "temperature"
                    },
                    "targetTemperatureF": {
                      "disabled": true,
                      "type": "temperature"
                    }
                  },
                  "condition": {
                    "operand_1": {
                      "operand_1": "value",
                      "operand_2": "FANONLY",
                      "operator": "eq"
                    },
                    "operand_2": {
                      "operand_1": "value",
                      "operand_2": "DRY",
                      "operator": "eq"
                    },
                    "operator": "or"
                  }
                },
                {
                  "action": {
                    "targetTemperatureC": {
                      "disabled": false,
                      "type": "temperature"
                    },
                    "targetTemperatureF": {
                      "disabled": false,
                      "type": "temperature"
                    }
                  },
                  "condition": {
                    "operand_1": {
                      "operand_1": "value",
                      "operand_2": "FANONLY",
                      "operator": "ne"
                    },
                    "operand_2": {
                      "operand_1": "value",
