  "paths": {
    "/api/v1/appliances/{applianceId}/command": {
      "put": {
        "tags": [
          "Send command"
        ],
        "summary": "Send command to appliance",
        "description": "This endpoint will execute the received command on the specified appliance, and will return nothing on a success",
        "operationId": "sendCommandToAppliance",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "applianceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "999011524_00:94700001-443E070ABC12"
            },
            "example": "999011524_00:94700001-443E070ABC12"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "string",
                "example": {
                  "mode": "COOL",
                  "targetTemperatureC": 21
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Ok"
          },
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "example": {
                  "message": "Appliance already in desired state"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "example": {
                  "error": "developers_0003",
                  "message": "Resource is forbidden for the user"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "example": {
                  "error": "developers_0004",
                  "message": "Requested resource not found"
                }
              }
            }
          },
          "406": {
            "description": "Not acceptable",
            "content": {
              "application/json": {
                "example": {
                  "error": "developers_0006",
                  "message": "Command validation failed",
                  "detail": "Appliance disconnected"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "example": {
                  "error": "developers_0005",
                  "message": "Unexpected server error"
                }
              }
            }
          }
        }
      }
    },
